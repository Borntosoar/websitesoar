# Headless Shopify (Storefront API). These are PUBLIC, client-side-safe values.
# Copy to .env.local for local dev, and set them in Vercel for production.
NEXT_PUBLIC_SHOPIFY_DOMAIN=borntosoar.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_public_storefront_api_token

# Firebase Auth (powers /auth). PUBLIC client config. Without these the auth
# page runs in demo mode (local validation + success). Project settings →
# Your apps → SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
