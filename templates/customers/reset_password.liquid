<section class="section"><div class="container" style="max-width:480px">{% form "reset_customer_password" %}{{ form.errors | default_errors }}<h1 class="statement" style="margin-bottom:1.5rem">Reset password</h1><input type="password" name="customer[password]" placeholder="New password" style="width:100%;margin-bottom:.6rem"><input type="password" name="customer[password_confirmation]" placeholder="Confirm" style="width:100%;margin-bottom:1rem"><button class="btn btn--solid" type="submit" style="width:100%;justify-content:center">Reset</button>{% endform %}</div></section>
