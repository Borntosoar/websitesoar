<section class="section"><div class="container" style="max-width:480px">{% form "create_customer" %}{{ form.errors | default_errors }}<h1 class="statement" style="margin-bottom:1.5rem">Create account</h1><input name="customer[first_name]" placeholder="First name" style="width:100%;margin-bottom:.6rem"><input name="customer[last_name]" placeholder="Last name" style="width:100%;margin-bottom:.6rem"><input type="email" name="customer[email]" placeholder="Email" style="width:100%;margin-bottom:.6rem"><input type="password" name="customer[password]" placeholder="Password" style="width:100%;margin-bottom:1rem"><button class="btn btn--solid" type="submit" style="width:100%;justify-content:center">Create</button>{% endform %}</div></section>
