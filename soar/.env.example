# SOAR — Shopify Storefront API (commerce engine). Without these the site runs
# on placeholder content via isShopifyConfigured fallbacks (it never crashes).
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token

# Pre-launch password gate (step 4 — server enforcement).
SOAR_ACCESS_PASSWORD=
