# Shopify Storefront API — copy to .env.local and fill in real values.
# Without these, lib/shopify.ts throws at request time; the homepage UI does not depend on it.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-api-token

# Site password gate — visitors are redirected to /access until they enter this.
# Leave unset in development to disable the gate entirely.
SITE_PASSWORD=your-launch-password

# Entrance video URL — point to the Higgsfield CDN URL or a /public path.
# Omit to fall back to the glitch-shader entrance.
NEXT_PUBLIC_ENTRANCE_VIDEO_URL=
