<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#000000">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600&family=Newsreader:ital,opsz@1,6..72&display=swap">
    {{ 'soar.css' | asset_url | stylesheet_tag }}
    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
  </head>
  <body class="soar template-password">
    <div class="stars-grad" aria-hidden="true"></div>
    <main style="position:relative;z-index:1;min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:22px;padding:max(40px,env(safe-area-inset-top)) var(--pad) max(40px,env(safe-area-inset-bottom))">
      <img src="{{ 'soar-logo-white.png' | asset_url }}" alt="{{ shop.name }}" width="160" height="42" style="height:30px;width:auto">
      <h1 class="display" style="font-size:clamp(2.6rem,10vw,5.5rem)">Born to soar</h1>
      <p class="lede" style="margin:0 auto">{{ shop.password_message | default: 'The drop opens soon. Enter with your access key.' }}</p>
      {%- form 'storefront_password' -%}
        {%- if form.errors -%}<div class="soar-errors" style="margin:0 auto;max-width:360px">{{ form.errors | default_errors }}</div>{%- endif -%}
        <div class="soar-signup" style="max-width:360px;margin:0 auto;width:100%">
          <input type="password" name="password" placeholder="Password" aria-label="Password" required>
          <button type="submit" aria-label="Enter">{%- render 'icon', name: 'arrow' -%}</button>
        </div>
      {%- endform -%}
      {{ content_for_layout }}
    </main>
    <script src="{{ 'soar.js' | asset_url }}" defer></script>
  </body>
</html>
