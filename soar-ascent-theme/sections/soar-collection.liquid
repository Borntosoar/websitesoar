{%- comment -%}
  SOAR — Collection (editorial, featured-first product grid)
  A `collection` setting; renders product-card for products up to a limit.
  One large lead tile + supporting tiles. Eyebrow + .h2 header + view-all link.
{%- endcomment -%}

{%- liquid
  assign coll = section.settings.collection
  assign limit = section.settings.products_to_show | default: 5
  assign products = coll.products
-%}

<section class="soar-collection section" aria-label="{{ section.settings.heading | default: coll.title | default: 'Collection' | escape }}">
  <div class="wrap">

    <header class="soar-collection__head reveal">
      <div class="soar-collection__head-main">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h2 soar-collection__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- if coll != blank -%}
        <a class="link soar-collection__viewall" href="{{ coll.url }}">
          {{ section.settings.view_all_label | default: 'View all' }}
          {%- if coll.products_count > 0 %} <span class="tnum">({{ coll.products_count }})</span>{% endif -%}
        </a>
      {%- endif -%}
    </header>

    <span class="hair soar-collection__rule reveal" aria-hidden="true"></span>

    {%- if coll != blank and products.size > 0 -%}
      <div class="soar-collection__grid reveal">
        {%- for product in products limit: limit -%}
          <div class="soar-collection__cell{% if forloop.first %} soar-collection__cell--lead{% endif %}">
            {% render 'product-card', product: product, dark: false %}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%} Editor / empty fallback: onboarding placeholders. {%- endcomment -%}
      <div class="soar-collection__grid reveal">
        {%- for i in (1..limit) -%}
          <div class="soar-collection__cell{% if forloop.first %} soar-collection__cell--lead{% endif %}">
            <div class="soar-collection__ph">
              {{ 'product-' | append: i | placeholder_svg_tag: 'soar-collection__ph-svg' }}
              <div class="soar-collection__ph-meta">
                <span class="eyebrow">{{ 'onboarding.product_title' | t | default: 'Product name' }}</span>
                <span class="tnum">$0.00</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{%- style -%}
  #shopify-section-{{ section.id }} .soar-collection__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
  }
  #shopify-section-{{ section.id }} .soar-collection__heading { margin: 1rem 0 0; }
  #shopify-section-{{ section.id }} .soar-collection__viewall { white-space: nowrap; }
  #shopify-section-{{ section.id }} .soar-collection__rule {
    display: block;
    margin: 2rem 0 3rem;
  }
  #shopify-section-{{ section.id }} .soar-collection__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem 1rem;
  }
  #shopify-section-{{ section.id }} .soar-collection__cell--lead { grid-column: span 2; }

  #shopify-section-{{ section.id }} .soar-collection__ph {
    border: 1px solid var(--line-dark);
  }
  #shopify-section-{{ section.id }} .soar-collection__ph-svg {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--paper);
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .soar-collection__ph-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1rem;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .soar-collection__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem 1.5rem;
    }
    #shopify-section-{{ section.id }} .soar-collection__cell--lead {
      grid-column: span 2;
      grid-row: span 2;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "SOAR Collection",
  "tag": "section",
  "class": "soar-section soar-section--collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "This Week"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The current ascent"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 9,
      "step": 1,
      "label": "Products to show",
      "default": 5
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View-all label",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "SOAR Collection"
    }
  ]
}
{% endschema %}
