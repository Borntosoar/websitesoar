<div style="margin-top:8px">
  {%- form 'customer' -%}
    {%- if form.posted_successfully? -%}
      <p class="idx">You&rsquo;re on the list.</p>
    {%- else -%}
      <div class="soar-signup" style="max-width:320px;margin:0 auto">
        <input type="email" name="contact[email]" placeholder="Notify me" aria-label="Email">
        <button type="submit" aria-label="Join">{%- render 'icon', name: 'arrow' -%}</button>
      </div>
    {%- endif -%}
  {%- endform -%}
</div>
