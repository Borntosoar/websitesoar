<div class="wrap section soar-pagehead">
  <span class="eyebrow soar-pagehead__eyebrow">Account</span>
  <h1 class="h2" style="margin:14px 0 32px">Reset password</h1>
  {%- form 'reset_customer_password' -%}
    <div class="soar-form">
      {%- if form.errors -%}<div class="soar-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="soar-field"><label for="rp-pass">New password</label><input id="rp-pass" class="soar-input" type="password" name="customer[password]" required></div>
      <div class="soar-field"><label for="rp-conf">Confirm password</label><input id="rp-conf" class="soar-input" type="password" name="customer[password_confirmation]" required></div>
      <button class="btn" type="submit">Reset password</button>
    </div>
  {%- endform -%}
</div>
