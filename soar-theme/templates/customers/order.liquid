<section class="section"><div class="container" style="max-width:640px"><h1 class="statement" style="margin-bottom:1rem">{{ order.name }}</h1>{% for line in order.line_items %}<div class="ledger__row"><span>{{ line.title }} × {{ line.quantity }}</span><span>{{ line.final_line_price | money }}</span></div>{% endfor %}<div class="ledger__row"><span class="label">Total</span><span>{{ order.total_price | money }}</span></div></div></section>
