<section class="section"><div class="container" style="max-width:640px"><h1 class="statement" style="margin-bottom:1rem">Account</h1><p class="label">{{ customer.email }}</p><p style="margin:1.5rem 0"><a href="{{ routes.account_logout_url }}" class="btn btn--line">Sign out</a></p><h2 class="label">Orders</h2>{% for order in customer.orders %}<div class="ledger__row"><span class="label">{{ order.created_at | date: "%b %d, %Y" }}</span><a href="{{ order.customer_url }}">{{ order.name }} — {{ order.total_price | money }}</a></div>{% else %}<p>No orders yet.</p>{% endfor %}</div></section>
