<section class="section"><div class="container"><div class="rowtag"><span class="label">SOAR®</span><span class="label">Collections</span></div><div class="grid" style="margin-top:2rem">{% for collection in collections %}<a class="card" href="{{ collection.url }}"><div class="card__media">{% if collection.featured_image %}<img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:cover">{% else %}<span class="card__mono serif">{{ forloop.index }}</span>{% endif %}</div><div class="card__info"><h3>{{ collection.title }}</h3></div></a>{% endfor %}</div></div></section>
