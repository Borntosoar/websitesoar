<section class="section"><div class="container"><div class="rowtag"><span class="label">SOAR®</span><span class="label">Search</span></div><form action="{{ routes.search_url }}" method="get" role="search" class="drop__form" style="max-width:520px;margin-top:1rem"><input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search" aria-label="Search"><button class="btn btn--solid" type="submit">Search</button></form>{% if search.performed %}<div class="grid" style="margin-top:3rem">{% for item in search.results %}<a class="card" href="{{ item.url }}"><div class="card__media"><span class="card__mono serif">{{ forloop.index }}</span></div><div class="card__info"><h3>{{ item.title }}</h3></div></a>{% else %}<p>No results.</p>{% endfor %}</div>{% endif %}</div></section>
