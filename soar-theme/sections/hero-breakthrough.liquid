<section class="hero">
  <div class="hero__text">
    <p class="eyebrow" data-reveal>{{ section.settings.eyebrow | default: 'Minimalist streetwear — Est. MMXXIV' }}</p>
    <h1 class="hero__title" data-reveal="lines">
      <span>Growth begins where</span>
      <span>comfort <em class="serif">ends.</em></span>
    </h1>
    <p class="hero__lede" data-reveal data-delay="1">{{ section.settings.lede | default: 'Premium essentials, considered down to the seam and released in limited runs. Quiet on the outside. Loud in the doing.' }}</p>
    <div class="hero__cta" data-reveal data-delay="2">
      <a class="btn btn--solid" href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" data-magnetic>{{ section.settings.cta_text | default: 'Shop the drop' }}</a>
      <a class="btn btn--line" href="{{ section.settings.cta2_url | default: '/pages/world' }}" data-magnetic>{{ section.settings.cta2_text | default: 'Our world' }}</a>
    </div>
  </div>

  <div class="hero__panel" data-reveal data-delay="1">
    <span class="hero__panel-tag label">Vol.01 — Ascension</span>
    <svg class="symbol" viewBox="0 0 400 520" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <defs>
        <radialGradient id="bloom" cx="50%" cy="50%" r="50%">
          <stop offset="0" stop-color="#F3EEE3" stop-opacity="0.9" />
          <stop offset="100%" stop-color="#F3EEE3" stop-opacity="0" />
        </radialGradient>
      </defs>
      <circle class="symbol__light" cx="238" cy="150" r="140" fill="url(#bloom)" />
      <g class="symbol__box" fill="none" stroke="#E7E2D7" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
        <path d="M132 470 L272 470 L272 360 L132 360 Z" />
        <path d="M132 360 L172 330 L312 330 L272 360" />
        <path d="M272 470 L312 440 L312 330" />
        <path class="symbol__crack" d="M202 360 L212 398 L196 430 L206 470" stroke-width="1.1" />
        <path class="symbol__crack" d="M172 344 L236 344" stroke-width="1.1" />
      </g>
      <path class="symbol__fragment" d="M242 330 L312 330 L292 360 Z" fill="none" stroke="#E7E2D7" stroke-width="1.4" stroke-linejoin="round" />
      <g class="symbol__bird">
        <path class="wing wing--l" d="M-3 -2 L-22 -16 L-5 4 Z" />
        <path class="wing wing--r" d="M3 -2 L22 -16 L5 4 Z" />
        <path class="bird-body" d="M0 -14 L4 6 L0 12 L-4 6 Z" />
      </g>
    </svg>
    <span class="hero__panel-foot label">Breakthrough — not flight</span>
  </div>
</section>
{% schema %}
{
  "name": "Hero — Breakthrough",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Minimalist streetwear — Est. MMXXIV" },
    { "type": "textarea", "id": "lede", "label": "Lede" },
    { "type": "text", "id": "cta_text", "label": "Primary CTA text", "default": "Shop the drop" },
    { "type": "url", "id": "cta_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta2_text", "label": "Secondary CTA text", "default": "Our world" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA link" }
  ],
  "presets": [{ "name": "Hero — Breakthrough" }]
}
{% endschema %}
