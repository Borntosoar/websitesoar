<section class="strip" id="lookbook">
  <div class="container strip__inner">
    <p class="strip__quote" data-reveal>Every garment is a reminder that you were <em class="serif">made to rise.</em></p>
    <a class="btn btn--paper" href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" data-magnetic>{{ section.settings.cta_text | default: 'See the lookbook' }}</a>
  </div>
</section>
{% schema %}
{
  "name": "Lookbook strip",
  "settings": [
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "See the lookbook" },
    { "type": "url", "id": "cta_url", "label": "Button link" }
  ],
  "presets": [{ "name": "Lookbook strip" }]
}
{% endschema %}
