<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#000000">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>
      {{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}
    </title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@300;400;500;600;700&family=Newsreader:ital,wght@0,400;1,400;1,500&display=swap" rel="stylesheet">

    {{ 'soar.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --oat: {{ settings.col_bg | default: '#FFFFFF' }};
        --ink: {{ settings.col_ink | default: '#000000' }};
        --espresso: {{ settings.col_dark | default: '#000000' }};
        --accent: {{ settings.col_accent | default: '#000000' }};
        --accent-2: {{ settings.col_accent2 | default: '#000000' }};
      }
    </style>
    {{ content_for_header }}
  </head>

  <body class="template-{{ template.name }}">
    <a class="skip-link" href="#MainContent">Skip to content</a>
    <div class="cd-progress" data-progress aria-hidden="true"></div>
    <div class="cursor" data-cursor aria-hidden="true"></div>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
    {% section 'cart-drawer' %}

    <script type="module">
      import Lenis from 'https://cdn.jsdelivr.net/npm/lenis@1.1.20/dist/lenis.mjs';
      const lenis = new Lenis({ duration: 1.1, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
      window.lenis = lenis;
      const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
      requestAnimationFrame(raf);
    </script>
    <script src="{{ 'soar.js' | asset_url }}" defer></script>
    <script src="{{ 'soar-enhance.js' | asset_url }}" defer></script>
  </body>
</html>
